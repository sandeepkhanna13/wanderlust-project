
<style>
    .search-btn{
        background-color:#fff;
        color:#000000;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 25px;
        padding: 0rem 1rem 0rem 1rem;
        border-color: #fe424d;
    }
    .search-btn:hover{
        background-color: #fe424d;
        color:#fff;
        border-color: black;
    }
    .search-btn i{
        margin-right: 0.5rem;
    }
    .search-input{
        border-radius: 25px;
        padding: 0.5rem 3rem;
        font-size: 1rem;
        
    }
    .search-input:focus {
        border-color: #fe424d !important;
        box-shadow: none !important;    
    }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
            <div class="navbar-nav">
                <a class="nav-link" href="/listings">Explore</a>
            </div>

            <div class="navbar-nav ms-auto">
                <nav class="navbar">
                    <div class="container-fluid">
                        <form class="d-flex" role="search" action="/listings" method="get">
                            <input class="form-control me-2 search-input" type="search" placeholder="Search country" name="country"/>
                            <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Search</button>
                        </form>
                    </div>
                </nav>
            </div>

            <div class="navbar-nav ms-auto all-links">
                <a class="nav-link" id="add" href="/listings/new">Airbnb your home</a>
            <% if(typeof currentUser !=="undefined" && currentUser && currentUser.role==="admin" ) { %>
                    <a class="nav-link" href="admin/dashboard">Admin Panel</a>
                    <% } %>
                <% if(!currentUser){%>
                    <a class="nav-link" href="/signup"><b>Sign up</b></a>
                    <a class="nav-link" href="/login"><b>Log in</b></a>
                <%}%>
                <%if(currentUser){%>
                    <a class="nav-link" href="/logout"><b>Log out</b></a>
                <%}%>
            </div>
        </div>
    </div>
</nav>